class Solution {
    public boolean isIsomorphic(String s, String t) {
        // to store mapping
        HashMap<Character,Character> map = new HashMap<>();
        // to ensure no 2 char map to same char in t
        HashSet<Character> used = new HashSet<>();
        if(s.length() != t.length()){
            return false;
        }
        for(int i=0;i<s.length();i++){
            char ch1 = s.charAt(i); // s char
            char ch2 = t.charAt(i);// t char
            // check it present in map or not
            if(map.containsKey(ch1)){
        // means if current char in s alredy mapped  to diffent char in t there is false as per rule
                if(map.get(ch1) != ch2){
                    return false;
                }
            }
            else{
                // means if t char is alredy mapped by any other char of s there is break of rule
                if(used.contains(ch2)){
                    return false;
                }
                map.put(ch1,ch2);
                used.add(ch2);
            }
        }
    return true;
    }
}
